{
  "main": "dist/_worker.js/index.js",
"name": "astro-sgds",
  "compatibility_date": "2026-03-17", // Update to the day you deploy
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}